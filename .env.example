# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin notification: POST payload to this URL on successful payment (e.g. Zapier/Make/WhatsApp/Email)
ADMIN_WEBHOOK_URL=https://hooks.zapier.com/...
# Optional: base URL for redirects (Vercel: https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Google Maps — Directions (traffic-aware ETA) + Places Autocomplete on order form (enable Places API + Directions API)
# GOOGLE_MAPS_API_KEY=

# Optional: Vercel Cron — must match the secret configured in the Vercel project (Cron → order-reminders)
# CRON_SECRET=

# Optional: disable per-IP API throttling (local load tests only)
# RATE_LIMIT_DISABLED=1

# Optional: sign-off name in German “thank you / delivery” customer emails
# EMAIL_SIGNOFF_NAME=Max Mustermann
